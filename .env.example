# ==============================================
# Jolly Pet Website — Environment Variables
# Copy this file to .env.local and fill in values
# ==============================================

# ---- Supabase (https://supabase.com) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- NextAuth.js ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_URL=http://localhost:3000

# ---- Gmail SMTP (Nodemailer) ----
# Use Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=jollypet.hq@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM="Jolly Pet <jollypet.hq@gmail.com>"

# ---- PromptPay ----
PROMPTPAY_ID=0812345678
# หรือเลขทะเบียนนิติบุคคล (13 หลัก)
# PROMPTPAY_ID=0105567890123

# ---- Bank Transfer ----
BANK_NAME=กสิกรไทย
BANK_ACCOUNT_NAME=บริษัท จอลลี่ เพ็ท จำกัด
BANK_ACCOUNT_NUMBER=xxx-x-xxxxx-x

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Jolly Pet
NEXT_PUBLIC_COMPANY_NAME=บริษัท จอลลี่ เพ็ท จำกัด
NEXT_PUBLIC_COMPANY_TAX_ID=xxxxxxxxxxxx

# ---- Omise (Phase 5 — optional) ----
# OMISE_PUBLIC_KEY=pkey_xxxxx
# OMISE_SECRET_KEY=skey_xxxxx
